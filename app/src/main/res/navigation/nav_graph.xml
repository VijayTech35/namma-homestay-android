<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Auth Flow -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.nammahomestay.ui.auth.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_guestHome"
            app:destination="@id/guestHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_hostDashboard"
            app:destination="@id/hostDashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_adminPanel"
            app:destination="@id/adminPanelFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.nammahomestay.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_otp"
            app:destination="@id/otpFragment" />
        <action
            android:id="@+id/action_login_to_roleSelection"
            app:destination="@id/roleSelectionFragment" />
        <action
            android:id="@+id/action_login_to_guestHome"
            app:destination="@id/guestHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_hostDashboard"
            app:destination="@id/hostDashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_adminPanel"
            app:destination="@id/adminPanelFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/otpFragment"
        android:name="com.nammahomestay.ui.auth.OtpFragment"
        android:label="OTP Verification"
        tools:layout="@layout/fragment_otp">
        <action
            android:id="@+id/action_otp_to_roleSelection"
            app:destination="@id/roleSelectionFragment" />
    </fragment>

    <fragment
        android:id="@+id/roleSelectionFragment"
        android:name="com.nammahomestay.ui.auth.RoleSelectionFragment"
        android:label="Select Role"
        tools:layout="@layout/fragment_role_selection">
        <action
            android:id="@+id/action_roleSelection_to_guestHome"
            app:destination="@id/guestHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_roleSelection_to_hostDashboard"
            app:destination="@id/hostDashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Guest Flow -->
    <fragment
        android:id="@+id/guestHomeFragment"
        android:name="com.nammahomestay.ui.guest.GuestHomeFragment"
        android:label="HomeStays"
        tools:layout="@layout/fragment_guest_home">
        <action
            android:id="@+id/action_guestHome_to_homeStayDetail"
            app:destination="@id/homeStayDetailFragment" />
        <action
            android:id="@+id/action_guestHome_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeStayDetailFragment"
        android:name="com.nammahomestay.ui.guest.HomeStayDetailFragment"
        android:label="HomeStay Details"
        tools:layout="@layout/fragment_home_stay_detail" />

    <!-- Host Flow -->
    <fragment
        android:id="@+id/hostDashboardFragment"
        android:name="com.nammahomestay.ui.host.HostDashboardFragment"
        android:label="My HomeStays"
        tools:layout="@layout/fragment_host_dashboard">
        <action
            android:id="@+id/action_hostDashboard_to_addHomeStay"
            app:destination="@id/addHomeStayFragment" />
        <action
            android:id="@+id/action_hostDashboard_to_inquiries"
            app:destination="@id/inquiriesFragment" />
        <action
            android:id="@+id/action_hostDashboard_to_dailyMenu"
            app:destination="@id/dailyMenuFragment" />
        <action
            android:id="@+id/action_hostDashboard_to_addGuidePlace"
            app:destination="@id/addGuidePlaceFragment" />
        <action
            android:id="@+id/action_hostDashboard_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/addHomeStayFragment"
        android:name="com.nammahomestay.ui.host.AddHomeStayFragment"
        android:label="Add HomeStay"
        tools:layout="@layout/fragment_add_home_stay" />

    <fragment
        android:id="@+id/inquiriesFragment"
        android:name="com.nammahomestay.ui.host.InquiriesFragment"
        android:label="Inquiries"
        tools:layout="@layout/fragment_inquiries" />

    <fragment
        android:id="@+id/dailyMenuFragment"
        android:name="com.nammahomestay.ui.host.DailyMenuFragment"
        android:label="Daily Menu"
        tools:layout="@layout/fragment_daily_menu" />

    <fragment
        android:id="@+id/addGuidePlaceFragment"
        android:name="com.nammahomestay.ui.host.AddGuidePlaceFragment"
        android:label="Add Guide Place"
        tools:layout="@layout/fragment_add_guide_place" />

    <!-- Admin -->
    <fragment
        android:id="@+id/adminPanelFragment"
        android:name="com.nammahomestay.ui.admin.AdminPanelFragment"
        android:label="Admin Panel"
        tools:layout="@layout/fragment_admin_panel" />

    <!-- Settings -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.nammahomestay.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
